# AI SAFE2 MCP Server — Environment Configuration
# Copy to .env and fill in real values.
# NEVER commit .env to version control. Add it to .gitignore.

# ── Transport ─────────────────────────────────────────────────────────────────
# stdio: local use (Claude Code, Codex, no network, no auth needed)
# streamable-http: remote deployment via HTTPS (Railway, self-hosted + Caddy)
MCP_TRANSPORT=streamable-http

# HTTP bind address (localhost only — Caddy handles external TLS)
MCP_HOST=0.0.0.0
MCP_PORT=8000

# ── Domain (for Caddy HTTPS) ──────────────────────────────────────────────────
# Your public domain pointing to this server
DOMAIN=mcp.yourdomain.com

# ── Token Management ──────────────────────────────────────────────────────────
# Format: comma-separated "token:tier" pairs
# Tokens are issued at cyberstrategyinstitute.com/ai-safe2/
# This server only validates — it never issues tokens.
#
# Token prefixes (by convention):
#   free_ = free tier (email registration)
#   pro_  = pro tier (Toolkit purchase)
#
# Example (replace with real tokens from your token store):
# TOKENS=free_abc123def456:free,pro_xyz789uvw012:pro,pro_another_token:pro
TOKENS=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# json: structured JSON logs (recommended for production)
# console: human-readable (recommended for development)
LOG_FORMAT=json

# ── Notes ─────────────────────────────────────────────────────────────────────
# For Railway deployment:
#   Set all env vars in Railway dashboard under project settings.
#   Railway provides automatic HTTPS — you may not need Caddy on Railway.
#   Use the Railway-provided domain or connect a custom domain.
#   Set MCP_HOST=0.0.0.0 so Railway can forward traffic to the container.
#
# For local stdio use:
#   MCP_TRANSPORT=stdio
#   No TOKENS needed (auth is bypassed for stdio — it is a local process pipe).
#   Run: python -m mcp_server.app
#   Or:  docker run --rm -i -e MCP_TRANSPORT=stdio ai-safe2-mcp
