# NEXUS Sovereign Gateway -- Environment Configuration
# Copy to .env and customize before running docker compose up
#
# SECURITY: Never commit .env to version control.
# Add .env to .gitignore before your first commit.

# ============================================================================
# NEXUS CORE
# ============================================================================

# Trust domain for SPIFFE/SPIRE workload attestation
NEXUS_TRUST_DOMAIN=nexus.local

# Deployment environment (development | staging | production)
NEXUS_ENV=development

# Guardian failover mode: FAIL_CLOSED (default, recommended) | FAIL_OPEN | FAIL_MANDATE_ONLY
# FAIL_CLOSED: deny all actions when Guardian is unavailable
# FAIL_OPEN: allow all actions when Guardian is unavailable (DANGEROUS in production)
# FAIL_MANDATE_ONLY: allow only pre-authorized Action Mandate actions
GUARDIAN_FAIL_MODE=FAIL_CLOSED

# Enable post-quantum cryptography (ML-KEM-1024 + ML-DSA-65, FIPS 203/204)
# Set to 1 for NEXUS-Full mode. Requires liboqs in the gateway image.
NEXUS_PQC_ENABLED=0

# ============================================================================
# MCP UPSTREAM SERVERS
# ============================================================================

# Comma-separated list of upstream MCP server URLs to wrap with NEXUS governance.
# All MCP tool calls through the gateway receive CAEL envelope governance,
# Guardian policy enforcement, NOR fingerprinting, and JouleWork accounting.
# Example: http://filesystem-mcp:3000,http://postgres-mcp:3001
UPSTREAM_MCP_URLS=

# ============================================================================
# JOULEWORK ECONOMIC ACCOUNTS
# ============================================================================

# Initial JouleWork credit allocation per new agent (in compute units)
# Agents that exhaust their credit trigger ZHC Solvency Constraint Protocol
JOULEWORK_INITIAL_CREDIT=10000

# ============================================================================
# REDIS
# ============================================================================

# Redis password (change in production; do not use the default)
REDIS_PASSWORD=nexus-dev-password

# ============================================================================
# OBSERVABILITY
# ============================================================================

# OPA log level: error | info | debug
OPA_LOG_LEVEL=error

# Gateway log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ============================================================================
# SIEM INTEGRATION (configure in otel/collector-config.yaml)
# ============================================================================

# Splunk HEC endpoint (leave blank to disable)
SPLUNK_HEC_ENDPOINT=
SPLUNK_HEC_TOKEN=

# Elasticsearch endpoint (leave blank to disable)
ELASTIC_ENDPOINT=

# Datadog API key (leave blank to disable)
DATADOG_API_KEY=
