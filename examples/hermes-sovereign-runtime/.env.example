# Hermes Sovereign Runtime — Environment Configuration
# Cyber Strategy Institute · AI SAFE² v3.0
#
# Copy this file: cp .env.example .env
# Edit .env — do NOT commit .env to version control
# Minimum required: one LLM provider key + AUDIT_CHAIN_KEY

# ─── REQUIRED ────────────────────────────────────────────────────────────────

# Generate with: openssl rand -hex 32
# Used for audit log HMAC integrity chain — lose this and logs cannot be verified
AUDIT_CHAIN_KEY=

# ─── LLM PROVIDER (set at least one) ─────────────────────────────────────────

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
NVIDIA_NIM_API_KEY=
HF_API_KEY=

# ─── VAULT ────────────────────────────────────────────────────────────────────

# Development: use default dev token
# Production: replace with AppRole/Kubernetes auth
VAULT_ROOT_TOKEN=hsr-dev-token

# ─── ISHI SUPERVISOR ─────────────────────────────────────────────────────────

# Anomaly score threshold to activate kill switch (0.0-1.0)
# Default 0.85 — lower to be more aggressive
ISHI_ANOMALY_THRESHOLD=0.85

# Webhook for kill switch alerts (Slack, PagerDuty, etc.)
# Example: https://hooks.slack.com/services/T.../B.../...
ALERT_WEBHOOK_URL=

# ─── OBSERVABILITY ───────────────────────────────────────────────────────────

# Change this before first deploy
GRAFANA_PASSWORD=hsr-change-me

# ─── OPTIONAL GATEWAY OVERRIDES ──────────────────────────────────────────────

# Active LLM provider: anthropic | openai | openrouter | gemini | ollama
# GATEWAY_PROVIDER=anthropic

# Custom upstream base URL (e.g., Azure OpenAI endpoint)
# GATEWAY_UPSTREAM_BASE_URL=

# Maximum LLM request size in bytes (default 32KB)
# GATEWAY_MAX_REQUEST_SIZE=32768

# ─── CRITICAL HERMES SECURITY OVERRIDES ─────────────────────────────────────
# These MUST be set. Defaults are insecure. Do NOT change without reviewing
# docs/THREAT-MODEL.md first.

# CRITICAL: Overrides container approval bypass (CVE finding, April 2026 audit)
# Default behavior in Docker: ALL approvals disabled. This fixes it.
HERMES_FORCE_APPROVAL=true

# CRITICAL: Restricts agent file read access to safe workspace only
# Prevents ~/.ssh, ~/.aws, ~/.env exfiltration via read_file tool
HERMES_READ_SAFE_ROOT=/opt/hermes/workspace

# CRITICAL: Route ALL LLM requests through HSR gateway (secrets + injection filter)
# Without this, all traffic bypasses the control plane
ANTHROPIC_BASE_URL=http://localhost:8000/v1

# CRITICAL: Never enable YOLO in production — disables ALL approval checks
HERMES_YOLO=false

# CRITICAL: Disable WeChat Work adapter — CVE-2026-7396 path traversal
WECOM_ENABLED=false
