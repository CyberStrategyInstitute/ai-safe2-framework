{
  "_comment": "AI SAFE2 Enterprise Managed Settings -- Linux",
  "_deploy_to": "/etc/claude-code/managed-settings.json",
  "_managed_by": "Security Team -- do not modify manually",
  "_framework": "AI SAFE2 / AISM Level 4",

  "bypassPermissions": false,
  "autoUpdaterStatus": "disabled",

  "allowedTools": {
    "WebFetch": false,
    "Bash": true,
    "Write": true,
    "Edit": true,
    "Read": true,
    "Task": true
  },

  "allowManagedHooksOnly": true,

  "managedHooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/etc/claude-code/hooks/pre-tool-use.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/etc/claude-code/hooks/post-tool-use.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/etc/claude-code/hooks/stop.sh"
          }
        ]
      }
    ]
  },

  "permissions": {
    "deny": [
      "Bash(curl *|*sh)",
      "Bash(wget *|*sh)",
      "Bash(rm -rf /*)",
      "Bash(sudo rm *)",
      "Bash(*base64 -d*|*sh*)",
      "Bash(env | curl*)",
      "Bash(printenv | curl*)"
    ]
  },

  "remoteControl": {
    "enabled": false
  },

  "telemetry": {
    "enabled": true,
    "centralLogEndpoint": "https://your-siem.internal/claude-code"
  }
}
