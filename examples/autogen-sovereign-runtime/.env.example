# AI SAFE² v3.0 — LangChain Sovereign Runtime Configuration
# Copy to .env and edit before running.
# Never commit .env to version control.

# ── CP.3: ACT Capability Tier ─────────────────────────────────────────────
# ACT1 = Assisted (log only, human reviews all outputs)
# ACT2 = Supervised (log + SSRF/path blocks raise, human checkpoints)
# ACT3 = Autonomous (fail-closed on all critical violations) ← recommended
# ACT4 = Orchestrator (ACT-3 + mandatory HEAR gate)
AISAFE2_ACT_TIER=ACT3

# ── A2.5: Audit Log Directory ─────────────────────────────────────────────
# OCSF 1.1 SHA-256 chain logs. Must be outside agent-accessible paths.
AISAFE2_AUDIT_LOG_DIR=~/.ai_safe2/audit

# ── P1.T2.3: Outbound Domain Allowlist ───────────────────────────────────
# Comma-separated. Subdomains are allowed (e.g., api.openai.com allows
# chat.api.openai.com). Leave empty to skip domain enforcement.
AISAFE2_ALLOWED_DOMAINS=api.openai.com,api.anthropic.com

# ── F3.2: Agent Recursion Limit Governor ─────────────────────────────────
# Hard ceiling on total tool calls per session. NOT a system prompt hint.
AISAFE2_MAX_TOOL_CALLS=50

# ── M4.5: Tool-Misuse Loop Detection ─────────────────────────────────────
# Max identical (tool + args hash) calls before CircuitTripped is raised.
AISAFE2_MAX_IDENTICAL_CALLS=4

# ── CP.4: Agent Identity (fill for production deployments) ───────────────
AISAFE2_AGENT_ID=my-langchain-agent-prod-01
AISAFE2_OWNER_OF_RECORD=your.name@yourcompany.com
AISAFE2_CONTROL_PLANE_ID=langchain-prod-cp-001

# ── LangChain API Keys (your existing keys — not managed by AI SAFE²) ────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# LANGCHAIN_API_KEY=ls-...
# LANGCHAIN_TRACING_V2=true

# ── AutoGen 0.4-specific ──────────────────────────────────────────────────
# P1.T1.2: code block scanning (always enabled at ACT-3+)
AISAFE2_AG_SCAN_PYTHON=true
AISAFE2_AG_SCAN_SHELL=true
# CP.8: fail on catastrophic code patterns even below ACT-3
AISAFE2_AG_CP8_FAIL_ALL_TIERS=true
